
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Student profile tracking progress, star rewards, and social status.",
      "properties": {
        "displayName": { "type": "string" },
        "totalStars": { "type": "number" },
        "badges": { "type": "array", "items": { "type": "string" } },
        "role": { "type": "string", "enum": ["student", "admin"] },
        "age": { "type": "number" },
        "preferences": { "type": "array", "items": { "type": "string" } },
        "onboardingCompleted": { "type": "boolean" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["displayName", "totalStars", "role"]
    },
    "Lesson": {
      "title": "Lesson",
      "type": "object",
      "description": "Educational lesson content split into interactive steps.",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "steps": { "type": "array", "items": { "type": "string" } },
        "imageUrl": { "type": "string" },
        "ageRange": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "steps", "category"]
    },
    "Post": {
      "title": "Post",
      "type": "object",
      "description": "Social post shared by students.",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "likes": { "type": "array", "items": { "type": "string" } },
        "commentCount": { "type": "number" },
        "isGuruResponse": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Message": {
      "title": "Message",
      "type": "object",
      "description": "Private message between students.",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Student profiles."
    },
    "/lessons/{lessonId}": {
      "schema": { "$ref": "#/backend/entities/Lesson" },
      "description": "Lessons curriculum."
    },
    "/posts/{postId}": {
      "schema": { "$ref": "#/backend/entities/Post" },
      "description": "Social feed posts."
    },
    "/messages/{messageId}": {
      "schema": { "$ref": "#/backend/entities/Message" },
      "description": "Direct messages."
    }
  }
}
