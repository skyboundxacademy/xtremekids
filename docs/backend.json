
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Student profile tracking progress and star rewards.",
      "properties": {
        "displayName": { "type": "string" },
        "totalStars": { "type": "number" },
        "badges": { "type": "array", "items": { "type": "string" } },
        "role": { "type": "string", "enum": ["student", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["displayName", "totalStars", "role"]
    },
    "Lesson": {
      "title": "Lesson",
      "type": "object",
      "description": "Educational lesson content managed by admins.",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "category"]
    },
    "Task": {
      "title": "Task",
      "type": "object",
      "description": "A daily or weekly mission for students to complete.",
      "properties": {
        "title": { "type": "string" },
        "points": { "type": "number" },
        "type": { "type": "string", "enum": ["daily", "weekly"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "points", "type"]
    },
    "Submission": {
      "title": "Submission",
      "type": "object",
      "description": "Student task submission awaiting marking.",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "taskTitle": { "type": "string" },
        "points": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "taskTitle", "status"]
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Private student progress profiles."
    },
    "/lessons/{lessonId}": {
      "schema": { "$ref": "#/backend/entities/Lesson" },
      "description": "Public educational curriculum."
    },
    "/tasks/{taskId}": {
      "schema": { "$ref": "#/backend/entities/Task" },
      "description": "Global mission list for students."
    },
    "/submissions/{submissionId}": {
      "schema": { "$ref": "#/backend/entities/Submission" },
      "description": "Marking queue for student assignments."
    },
    "/roles_admin/{adminId}": {
      "schema": { 
        "title": "AdminMarker",
        "type": "object",
        "properties": { "adminId": { "type": "string" } }
      },
      "description": "Authorization list for professor access."
    }
  }
}
