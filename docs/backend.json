
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Student profile tracking progress, star rewards, and class level.",
      "properties": {
        "displayName": { "type": "string" },
        "totalStars": { "type": "number" },
        "badges": { "type": "array", "items": { "type": "string" } },
        "role": { "type": "string", "enum": ["student", "admin"] },
        "studentClass": { "type": "string", "description": "e.g., JSS 1, SSS 3, Primary 4" },
        "onboardingCompleted": { "type": "boolean" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["displayName", "totalStars", "role"]
    },
    "Lesson": {
      "title": "Lesson",
      "type": "object",
      "description": "Interactive educational content with polls and steps.",
      "properties": {
        "title": { "type": "string" },
        "subject": { "type": "string" },
        "category": { "type": "string" },
        "targetClass": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "steps": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["text", "image", "poll"] },
              "content": { "type": "string" },
              "imageUrl": { "type": "string" },
              "poll": {
                "type": "object",
                "properties": {
                  "question": { "type": "string" },
                  "options": { "type": "array", "items": { "type": "string" } },
                  "correctAnswer": { "type": "string" },
                  "explanation": { "type": "string" }
                }
              }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "subject", "steps"]
    },
    "Submission": {
      "title": "Submission",
      "type": "object",
      "description": "Record of a student completing a lesson or task.",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "taskTitle": { "type": "string" },
        "points": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Student profiles."
    },
    "/lessons/{lessonId}": {
      "schema": { "$ref": "#/backend/entities/Lesson" },
      "description": "Lessons curriculum."
    },
    "/submissions/{submissionId}": {
      "schema": { "$ref": "#/backend/entities/Submission" },
      "description": "Work submissions."
    }
  }
}
